{
  "mcpServers": {
    "geo-audit": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "tools/geo_audit_arcade",
        "python",
        "src/geo_audit_arcade/server.py",
        "stdio"
      ],
      "env": {
        "ANTHROPIC_API_KEY": ""
      }
    },
    "benchmark-control": {
      "command": "uv",
      "args": [
        "run",
        "--directory",
        "tools/benchmark_control_arcade",
        "python",
        "src/benchmark_control_arcade/server.py",
        "stdio"
      ],
      "env": {
        "GITHUB_TOKEN": "",
        "GITHUB_OWNER": "",
        "GITHUB_REPO": ""
      }
    }
  }
}
