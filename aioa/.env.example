# OpenAI — used for GPT-5.3 and GPT-5.2 model layer queries
OPENAI_API_KEY=sk-...

# Anthropic — used for Claude Sonnet 4.6 + Opus 4.6 model layer queries AND orchestrator
ANTHROPIC_API_KEY=sk-ant-...

# MCP Server — Arcade-hosted search endpoint (default: https://api.arcade.dev/mcp/AIO)
# MCP_SERVER_URL=https://api.arcade.dev/mcp/AIO

# Arcade auth — required for authenticated MCP endpoints
ARCADE_API_KEY=arc_...
ARCADE_USER_ID=you@example.com
