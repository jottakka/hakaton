{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeoCompareOutput",
  "description": "Structured output produced by the GEO competitive comparison agent for one benchmark run.",
  "type": "object",
  "required": ["target", "competitors", "run_date", "audits", "comparison_table", "winner_per_lever", "overall_winner", "report_markdown"],
  "additionalProperties": false,
  "properties": {
    "target": {
      "type": "string",
      "description": "The primary site being audited (e.g. 'arcade.dev')."
    },
    "competitors": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Competitor URLs audited alongside the target."
    },
    "run_date": {
      "type": "string",
      "format": "date",
      "description": "ISO-8601 date when this comparison run was executed (YYYY-MM-DD)."
    },
    "audits": {
      "type": "array",
      "description": "One entry per audited URL (target first, then competitors).",
      "items": {
        "type": "object",
        "required": ["url", "overall_score", "lever_scores", "artifacts", "strengths", "weaknesses", "recommendations"],
        "additionalProperties": false,
        "properties": {
          "url": {
            "type": "string",
            "description": "The audited site URL."
          },
          "overall_score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Sum of all four lever scores (each 0–25)."
          },
          "lever_scores": {
            "type": "object",
            "required": ["content_structure", "entity_authority", "technical", "citation"],
            "additionalProperties": false,
            "properties": {
              "content_structure": {
                "type": "integer",
                "minimum": 0,
                "maximum": 25,
                "description": "Lever 1: Content structure and extractability (0–25)."
              },
              "entity_authority": {
                "type": "integer",
                "minimum": 0,
                "maximum": 25,
                "description": "Lever 2: Entity authority (0–25)."
              },
              "technical": {
                "type": "integer",
                "minimum": 0,
                "maximum": 25,
                "description": "Lever 3: Technical accessibility — robots.txt, sitemaps, llms.txt, canonicals (0–25)."
              },
              "citation": {
                "type": "integer",
                "minimum": 0,
                "maximum": 25,
                "description": "Lever 4: Citation-worthiness (0–25)."
              }
            }
          },
          "artifacts": {
            "type": "object",
            "required": ["robots_txt", "sitemap_xml", "llms_txt", "llms_full_txt"],
            "additionalProperties": false,
            "properties": {
              "robots_txt": {
                "type": "string",
                "enum": ["found", "not_found", "redirect", "error"],
                "description": "Status of robots.txt discovery."
              },
              "sitemap_xml": {
                "type": "string",
                "enum": ["found", "not_found", "redirect", "error"],
                "description": "Status of sitemap.xml discovery."
              },
              "llms_txt": {
                "type": "string",
                "enum": ["found", "not_found", "redirect", "error"],
                "description": "Status of llms.txt discovery."
              },
              "llms_full_txt": {
                "type": "string",
                "enum": ["found", "not_found", "redirect", "error"],
                "description": "Status of llms-full.txt discovery."
              }
            }
          },
          "strengths": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Observable strengths with evidence."
          },
          "weaknesses": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Observed weaknesses with evidence."
          },
          "recommendations": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Concrete actionable recommendations tied to specific URLs."
          }
        }
      }
    },
    "comparison_table": {
      "type": "string",
      "description": "Markdown table showing all URLs side by side across all four levers and overall score."
    },
    "winner_per_lever": {
      "type": "object",
      "required": ["content_structure", "entity_authority", "technical", "citation"],
      "additionalProperties": false,
      "properties": {
        "content_structure": {
          "type": "string",
          "description": "URL of the site with the highest content_structure score."
        },
        "entity_authority": {
          "type": "string",
          "description": "URL of the site with the highest entity_authority score."
        },
        "technical": {
          "type": "string",
          "description": "URL of the site with the highest technical score."
        },
        "citation": {
          "type": "string",
          "description": "URL of the site with the highest citation score."
        }
      }
    },
    "overall_winner": {
      "type": "string",
      "description": "URL of the site with the highest overall_score."
    },
    "report_markdown": {
      "type": "string",
      "description": "Full human-readable comparative audit report in Markdown format."
    }
  }
}
