{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeoSiteAuditOutput",
  "description": "Structured output produced by the GEO site audit agent for one benchmark run.",
  "type": "object",
  "required": ["target_url", "overall_score", "claims", "evidence", "report_markdown"],
  "additionalProperties": false,
  "properties": {
    "target_url": {
      "type": "string",
      "format": "uri",
      "description": "Canonical URL of the audited site or page."
    },
    "overall_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Sum of all four lever scores (each 0–25)."
    },
    "audit_mode": {
      "type": "string",
      "enum": ["exhaustive", "quick", "focused"],
      "description": "Audit mode used for this run.",
      "default": "exhaustive"
    },
    "claims": {
      "type": "array",
      "description": "One item per scored GEO lever.",
      "items": {
        "type": "object",
        "required": ["lever", "score", "strengths", "weaknesses", "confidence", "recommendations"],
        "additionalProperties": false,
        "properties": {
          "lever": {
            "type": "integer",
            "enum": [1, 2, 3, 4],
            "description": "Lever number (1=content structure, 2=entity authority, 3=technical, 4=citation)."
          },
          "lever_name": {
            "type": "string",
            "description": "Human-readable lever name."
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 25,
            "description": "Score for this lever out of 25."
          },
          "strengths": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "description": "3–5 observable strengths with evidence."
          },
          "weaknesses": {
            "type": "array",
            "items": {"type": "string"},
            "minItems": 1,
            "description": "3–5 observed weaknesses with evidence."
          },
          "confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"],
            "description": "Confidence level for this lever's score."
          },
          "recommendations": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Concrete actionable recommendations tied to specific URLs."
          }
        }
      }
    },
    "evidence": {
      "type": "array",
      "description": "Raw evidence items collected by CollectGeoEvidence.",
      "items": {
        "type": "object",
        "required": ["url", "type", "summary"],
        "additionalProperties": true,
        "properties": {
          "url": {
            "type": "string",
            "description": "Source URL for this evidence item."
          },
          "type": {
            "type": "string",
            "description": "Evidence type (e.g. 'page', 'robots_txt', 'sitemap', 'llms_txt', 'json_ld')."
          },
          "summary": {
            "type": "string",
            "description": "Short summary of what was found at this URL."
          },
          "raw": {
            "description": "Optional raw content or structured data extracted from the URL."
          }
        }
      }
    },
    "report_markdown": {
      "type": "string",
      "description": "Full human-readable audit report in Markdown format."
    },
    "metadata": {
      "type": "object",
      "description": "Optional run metadata (model, timestamps, etc.).",
      "additionalProperties": true
    }
  }
}
